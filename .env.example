# Atlas — environment variables example
# Copy this file to .env.local for local development (it's git-ignored).
# On Vercel, set these in: Dashboard → Project → Settings → Environment Variables
#
# IMPORTANT: use DIFFERENT values per environment:
#   - Production  → atlas-prod project keys
#   - Preview     → atlas-dev project keys
#   - Development → atlas-dev project keys
#
# The "anon" key is SAFE to expose in the browser — it's designed for client-side use
# and protected by Row Level Security on the database.
# NEVER commit or expose the service_role key. It bypasses RLS.

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
